# editor
alias vim="nvim"

# tmux
alias tmls="tmux ls"
alias tmn="tmux new -s"
alias tma="tmux attach-session -t"
alias tmk="tmux kill-session -t"
alias tmrls='ls ~/.local/share/tmux/resurrect/'

# file management
alias r="ranger"

# colima / kubernetes
alias cstart="colima start --arch aarch64 --vm-type=vz --vz-rosetta --mount-type 9p"
alias start_k8s="colima start --kubernetes"

# http clients — install: uv tool install posting
alias posting="uvx posting"

# mcp inspector
alias mcpjam="npx @mcpjam/inspector@latest"