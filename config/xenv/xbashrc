#!/bin/bash
#
# xbashrc — main shell environment, sourced from ~/.bash_profile

# Terminal: make directory listings readable (default blue is too dark)
LS_COLORS='di=0;35'; export LS_COLORS

# --- Detect OS and architecture ---
OS=$(uname -s)
MARCH=$(uname -m)

# macOS
if [ "$OS" == "Darwin" ]; then
  export BASH_SILENCE_DEPRECATION_WARNING=1
  echo "$OS $USER ${TERM_PROGRAM:-terminal} $MARCH"
  export PATH=/opt/homebrew/bin:${PATH}
  export PATH=${PATH}:/Applications/Visual\ Studio\ Code.app/Contents/Resources/app/bin
  BINPATH="${OS}_${MARCH}"
  export PATH=$PATH:~/Workspace/bin/$BINPATH:~/go/bin
  export PATH=$HOME/.local/bin:$PATH
fi

# Linux
if [ "$OS" == "Linux" ]; then
  echo "$OS $USER ${TERM_PROGRAM:-terminal} $MARCH"
  export PATH=/usr/local/bin:$HOME/.local/bin:${PATH}
fi

# Sometimes Neovim fails with MallocStackLogging set
unset MallocStackLogging

# --- Environment defaults (non-secret) ---
if [ -f ~/.config/xenv/env.sh ]; then
  . ~/.config/xenv/env.sh
fi

# --- Secrets and machine-specific overrides ---
if [ -f ~/.config/xenv/.env ]; then
  . ~/.config/xenv/.env
fi

# --- AI / GenAI tools ---
if [ -f ~/.config/xenv/genai.sh ]; then
  . ~/.config/xenv/genai.sh
fi

# --- Aliases ---
if [ -f ~/.config/xenv/aliases ]; then
  . ~/.config/xenv/aliases
fi

# --- Language environments ---
if [ -f ~/.config/xenv/gitenv.sh ]; then
  . ~/.config/xenv/gitenv.sh
fi
if [ -f ~/.config/xenv/goenv.sh ]; then
  . ~/.config/xenv/goenv.sh
fi
if [ -f ~/.config/xenv/pyenv.sh ]; then
  . ~/.config/xenv/pyenv.sh
fi
if [ -f ~/.config/xenv/rustenv.sh ]; then
  . ~/.config/xenv/rustenv.sh
fi
